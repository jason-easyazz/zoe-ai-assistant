{
  "mcpServers": {
    "serena": {
      "command": "/home/zoe/.local/bin/serena",
      "args": ["start-mcp-server", "--context", "ide-assistant", "--project", "/home/zoe/assistant", "--transport", "stdio", "--enable-web-dashboard", "false"]
    },
    "codebase-memory": {
      "command": "/home/zoe/.local/bin/codebase-memory-mcp"
    },
    "zoe-tools": {
      "command": "/home/zoe/.local/bin/uv",
      "args": [
        "run",
        "--with",
        "fastmcp",
        "--with",
        "httpx",
        "/home/zoe/bin/zoe-tools-mcp.py"
      ],
      "env": {
        "ZOE_DATA_URL": "http://127.0.0.1:8000",
        "MULTICA_API_URL": "http://127.0.0.1:8080"
      }
    }
  }
}
