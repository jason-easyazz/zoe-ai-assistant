{
  "name": "flue-executor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Lab-only Phase-1 spike: Flue-based Multica executor (claim -> spawn -> report -> reap). NOT wired into production.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "flue build --target node",
    "typecheck": "tsc --noEmit",
    "executor": "node --experimental-strip-types src/executor.ts",
    "e2e": "node --experimental-strip-types src/e2e.ts"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.6",
    "hono": "^4.8.3",
    "pg": "^8.13.1",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.6",
    "@types/node": "22.10.2",
    "@types/pg": "8.11.10",
    "typescript": "5.7.2"
  }
}
