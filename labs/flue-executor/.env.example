# --- lab mode (default) — `npm run e2e` / `npm run executor` --------------
# All optional; defaults derive the scratch-DB URL from the live service env file.
# LAB_DATABASE_URL=postgresql://user:pass@localhost:5432/multica_executor_lab
# ZOE_ENV_FILE=/home/zoe/assistant/services/zoe-data/.env
# LAB_POLL_MS=1000
# LAB_WORKER_TIMEOUT_MS=300000

# --- live mode — the supervised runner / flue-executor.service ------------
# ZOE_EXECUTOR_MODE=live is set by the unit; set it here too for a manual run.
# ZOE_EXECUTOR_MODE=live
# Dispatch stays `dry` (poll + log, mutate nothing) until you deliberately go live:
# ZOE_EXECUTOR_DISPATCH=dry
# The real Multica DB (derived from POSTGRES_URL by swapping the db name if unset):
# MULTICA_DATABASE_URL=postgresql://user:pass@localhost:5432/multica
# The kill switch the runner idles on while present (default shown):
# ZOE_MULTICA_KILL_SWITCH=/home/zoe/.zoe/multica_dispatch_paused

# --- Omnigent heavy lane (both modes) -------------------------------------
# LAB_OMNIGENT_URL=http://127.0.0.1:6767
# LAB_OMNIGENT_TIMEOUT_MS=600000
