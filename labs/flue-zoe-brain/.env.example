# Flue Zoe-brain sidecar — environment template.
# Copy to .env (gitignored) and fill in. NEVER commit real values.

# ── Agent-route auth — FAIL CLOSED: with neither set, every request is 401 ───
# Bearer token callers must present on POST /agents/zoe/:id.
ZOE_BRAIN_TOKEN=
# OR explicitly opt into open access (local hand-run smoke tests only):
#ZOE_BRAIN_OPEN=1

# ── Acting identity — REQUIRED; user-scoped tools fail closed without it ─────
# Bound in trusted code, never from model args. Guest-style ids are rejected.
ZOE_BRAIN_USER_ID=

# ── Capability backend (zoe-data) ─────────────────────────────────────────────
ZOE_DATA_URL=http://127.0.0.1:8000
# Sent as X-Internal-Token on every zoe-data call. Must be the SAME value as
# ZOE_INTERNAL_TOKEN in services/zoe-data/.env.
# REQUIRED once zoe-data sets ZOE_INTENT_DISPATCH_REQUIRE_TOKEN=1: this sidecar is the
# main caller of the gated /api/system/intent-dispatch + /api/system/delegate-sync, and
# with this unset every write turn 403s. Provision it here and restart BEFORE that flag
# is flipped (see services/zoe-data/.env.example for the full enable sequence).
ZOE_INTERNAL_TOKEN=

# ── Safety gates ──────────────────────────────────────────────────────────────
# Writes are DRY-RUN unless explicitly enabled (tools report "WRITE DISABLED").
ZOE_BRAIN_ALLOW_WRITES=false
# Hard per-turn tool-iteration ceiling (default 8).
#ZOE_BRAIN_MAX_TOOL_ITERS=8
# Progressive tool disclosure (default on). Set false to send every tool
# schema on every model call (A/B comparison only).
#ZOE_BRAIN_PROGRESSIVE_TOOLS=true

# ── Model endpoint (defaults to the live llama-server) ────────────────────────
#ZOE_BRAIN_BASE_URL=http://127.0.0.1:11434/v1
#ZOE_BRAIN_API_KEY=local-no-key

# ── Server / storage ──────────────────────────────────────────────────────────
# PORT is set by the systemd unit (3578); export it yourself for hand runs.
#PORT=3578
# Per-tool HTTP timeout against zoe-data (ms, default 8000).
#ZOE_BRAIN_TOOL_TIMEOUT_MS=8000
# Flue conversation/run durability DB (default <package>/data/zoe-brain.db).
#ZOE_BRAIN_DB=
