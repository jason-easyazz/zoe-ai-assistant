# Flue Zoe Telegram channel — LAB ONLY. Copy to .env; never commit a real .env.

# --- Telegram ---
# Bot token. Reuse Hermes's existing bot (it's paused, so no conflict); the bot
# moves from Hermes to here when this starts polling. From @BotFather otherwise.
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to talk to Zoe. FAIL-CLOSED: empty =
# nobody gets through. Your id is in ~/.hermes/.env as TELEGRAM_HOME_CHANNEL.
TELEGRAM_ALLOWED_USERS=

# --- Zoe's brain: zoe-data's /api/chat (the SAME pipeline voice + touch use) ---
# This channel does NOT call the local voice Gemma on :11434 — it asks zoe-data,
# which owns intent routing, tools, memory and persona. Default is correct on the
# Jetson; point elsewhere only to test against another zoe-data endpoint.
ZOE_BRAIN_URL=http://127.0.0.1:8000
# Optional: answer as a logged-in Zoe user (their memory) instead of guest. Set
# ONE of these to a valid zoe-auth session / device token; unset = guest identity.
# The allow-list controls WHO can reach the bridge; this controls WHICH Zoe user.
# ZOE_BRAIN_SESSION=
# ZOE_BRAIN_DEVICE_TOKEN=
