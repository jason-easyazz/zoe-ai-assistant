# Flue Zoe Telegram channel — LAB ONLY. Copy to .env; never commit a real .env.

# --- Telegram ---
# Bot token. Reuse Hermes's existing bot (it's paused, so no conflict); the bot
# moves from Hermes to here when this starts polling. From @BotFather otherwise.
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to talk to Zoe. FAIL-CLOSED: empty =
# nobody gets through. Your id is in ~/.hermes/.env as TELEGRAM_HOME_CHANNEL.
TELEGRAM_ALLOWED_USERS=

# --- Zoe's brain: the local Gemma llama-server (OpenAI-compatible) ---
# Same box as voice, but the voice fast-path is NOT routed through Flue. Default
# is correct on the Jetson. Point elsewhere only to test against another endpoint.
ZOE_BRAIN_BASE_URL=http://127.0.0.1:11434/v1
ZOE_BRAIN_API_KEY=not-needed
# Model string `zoe/<name>`; llama-server ignores the name and serves its gguf.
ZOE_MODEL=zoe/local
