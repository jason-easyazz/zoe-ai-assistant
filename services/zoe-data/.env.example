# Copy to .env and fill in. See openclaw_ws.py / auth.py for defaults.

# PostgreSQL is the live data store. Alembic migrations run during deploy.
# POSTGRES_URL=postgresql://zoe:replace-me@localhost:5432/zoe
# POSTGRES_APSCHEDULER_URL=postgresql+psycopg2://zoe:replace-me@localhost:5432/zoe
#
# Legacy SQLite path kept only for explicit migration/local-cache tooling.
# ZOE_DATA_DB=/home/zoe/assistant/services/zoe-data/data/zoe.db
# ZOE_AUTH_URL=http://localhost:8002
# Optional: requests without X-Session-ID get role guest (e.g. kiosk). Default: admin (legacy).
# ZOE_UNAUTHENTICATED_ROLE=***
# Shared secret for internal service-to-service calls (mcp_server → /api/internal/*).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# When unset the endpoint only accepts requests from 127.0.0.1/::1 (zero-config safe).
# ZOE_INTERNAL_TOKEN=
#
# Strict token gate for the ACTOR-ASSERTING endpoints — POST /api/system/intent-dispatch
# and POST /api/system/delegate-sync. Both take an arbitrary `user_id` in the BODY, so
# whoever satisfies the gate can write calendars/lists/memories/journals as ANY user, or
# reach Hermes via delegate-sync.
#   unset (DEFAULT): loopback OR a valid X-Internal-Token is trusted. Loopback alone is
#     reachable by any compromised/SSRF'd local process — i.e. the impersonation hole.
#     Every internal caller that does NOT prove the token logs a readiness WARNING.
#   1/true/yes/on: ONLY a valid X-Internal-Token passes; loopback is NOT sufficient.
#     Fails CLOSED — if ZOE_INTERNAL_TOKEN is unset, every request is denied.
#
# DO NOT flip this blind: it 403s every caller that does not send the token.
# Enable sequence (order matters):
#   1. Put the SAME ZOE_INTERNAL_TOKEN value in labs/flue-zoe-brain/.env (the brain
#      sidecar is the main caller and is the one env that typically still lacks it).
#   2. Restart flue-zoe-brain, then confirm the readiness WARNINGs stop in zoe-data's
#      journal — a quiet journal is the proof that every live caller now proves the token.
#   3. Only then set the flag here and restart zoe-data.
# Rollback: unset/comment this line and restart zoe-data (reverts to loopback trust).
# ZOE_INTENT_DISPATCH_REQUIRE_TOKEN=1
# OPENCLAW_AGENT_TIMEOUT_S=120
# OPENCLAW_GATEWAY_TOKEN=
# OPENWEATHERMAP_API_KEY=
# OPENCLAW_ALLOW_AUTO_UPDATE=false
# OPENCLAW_BACKGROUND_VERSION_CHECK=true
# OPENCLAW_UPGRADE_ENABLED=true
#
# ── Voice: STT (Moonshine) ────────────────────────────────────────────────
# Moonshine v2 Medium is the canonical STT rock for POST /api/voice/transcribe.
# ZOE_MOONSHINE_ARCH=MEDIUM_STREAMING
#
# ── Voice: TTS waterfall ─────────────────────────────────────────────────
# TTS mode: hybrid (local → kokoro → edge → espeak), local, cloud, edge, offline
# ZOE_TTS_MODE=hybrid
# Edge TTS voice (cloud fallback — Australian neural)
# ZOE_EDGE_TTS_VOICE=en-AU-NatashaNeural
# Edge TTS network timeout in seconds (failover to Kokoro ONNX on timeout)
# ZOE_EDGE_TTS_TIMEOUT_S=5
# Kokoro ONNX model path (download from https://github.com/thewh1teagle/kokoro-onnx/releases)
# ZOE_KOKORO_MODEL=/opt/models/kokoro-v1.0.onnx
# Kokoro voice: af_sky (AU female), bf_emma (UK female), af_bella (US female)
# ZOE_KOKORO_VOICE=af_sky
# URL for a running Kokoro/Piper sidecar service (optional, fastest path)
# ZOE_LOCAL_TTS_URL=http://localhost:8880
#
# ── Voice: wake acknowledgement phrase (spoken on wake word) ─────────────
# Leave empty to use only the wake beep. Set AUDIO_PATH to a pre-generated
# wav/mp3 file for instant websocket/Pi wake acknowledgement without live TTS.
# Use pipe-separated PHRASES/PATHS for a small cached response bank; entries are
# index-aligned and quote values when copying into .env, e.g.
# ZOE_WAKE_ACK_PHRASES="Yes Jason?|Good morning Jason.|Good evening Jason."
# Optional labels prefer time-aware variants: default|morning|evening
# ZOE_WAKE_ACK_VARIANT_LABELS="default|morning|evening"
# ZOE_WAKE_ACK_PHRASE=
# ZOE_WAKE_ACK_AUDIO_PATH=
# ZOE_WAKE_ACK_PHRASES=
# ZOE_WAKE_ACK_AUDIO_PATHS=
# ZOE_WAKE_ACK_VARIANT_LABELS=
#
# ── Voice: processing acknowledgement phrase (perceived latency) ─────────
# Short transition phrases for slow streamed/LiveKit turns. Use pre-generated
# audio paths for truly instant spoken feedback; live TTS is not used here.
# Defaults are enabled for text/data-channel acknowledgement only.
# ZOE_PROCESSING_ACK_DEFAULT_ENABLED=true
# ZOE_PROCESSING_ACK_PHRASE=
# ZOE_PROCESSING_ACK_AUDIO_PATH=
# ZOE_PROCESSING_ACK_PHRASES="Let me check.|One moment.|I will check that."
# ZOE_PROCESSING_ACK_AUDIO_PATHS=
#
# ── Voice: barge-in ──────────────────────────────────────────────────────
# BARGE_IN_ENABLED=true
# BARGE_IN_THRESHOLD=0.5
# POST_TTS_PROTECTION_MS=300
#
# ── Voice: ambient memory (always-on listening) ───────────────────────────
# OFF by default — opt in explicitly for privacy transparency.
# AMBIENT_CAPTURE_ENABLED=false
# AMBIENT_VAD_THRESHOLD=0.4
#
# ── Proactive: spoken delivery ("Zoe speaks first", P-W2.2) ──────────────
# OFF by default. When enabled, an allowlisted proactive trigger whose user
# has a FRESH foreground panel session additionally enqueues a panel_announce
# UI action, so the kiosk speaks the message. The push notification is ALWAYS
# still sent — spoken delivery is additive, never a replacement, and any
# spoken-path failure never blocks the push.
# ZOE_PROACTIVE_SPOKEN=false
# Comma-separated trigger allowlist for spoken delivery.
# ZOE_PROACTIVE_SPOKEN_TRIGGERS=morning_checkin
# Presence freshness window in seconds for panel_presence() (P-W2.1): a
# foreground ui_panel_sessions row seen within this window counts as "someone
# is plausibly at that panel".
# ZOE_PRESENCE_WINDOW_S=900
# Daemon announcement queue (P-W2.3): spoken deliveries also land in
# voice_announcements, claimed by the Pi voice daemon (device token) via
# GET /api/voice/announcements — the lane that actually reaches the speaker.
# TTL in seconds: an unclaimed announcement older than this is marked expired
# and NEVER spoken (a stale "good morning" at noon is worse than silence).
# ZOE_ANNOUNCE_TTL_S=120
# Restrict claims to rows whose panel_id equals the caller's device-token
# panel. OFF by default: presence records the BROWSER panel id while the
# daemon holds the DEVICE id (#817 alias mismatch), so strict matching would
# silently strand announcements in a one-speaker household.
# ZOE_ANNOUNCE_STRICT_PANEL=false
#
# ── Zoe Native OIDC SSO ───────────────────────────────────────────────────
# Authentik is retired. OIDC clients should point at zoe-auth.
# Generate client secrets with: python3 -c "import secrets; print(secrets.token_hex(50))"
# Example discovery URL: http://zoe.local/application/o/.well-known/openid-configuration
# OIDC_ISSUER_URL=
# OIDC_ZOE_CLIENT_ID=
# OIDC_ZOE_CLIENT_SECRET=
# HA_OIDC_CLIENT_ID=
# HA_OIDC_CLIENT_SECRET=
