# Copy to .env and fill in. See openclaw_ws.py / auth.py for defaults.

# ZOE_DATA_DB=/home/zoe/zoe-data/zoe.db
# ZOE_AUTH_URL=http://localhost:8002
# Optional: requests without X-Session-ID get role guest (e.g. kiosk). Default: admin (legacy).
# ZOE_UNAUTHENTICATED_ROLE=guest
# OPENCLAW_AGENT_TIMEOUT_S=120
# OPENCLAW_GATEWAY_TOKEN=
# OPENWEATHERMAP_API_KEY=
# OPENCLAW_ALLOW_AUTO_UPDATE=false
# OPENCLAW_BACKGROUND_VERSION_CHECK=true
# OPENCLAW_UPGRADE_ENABLED=true
#
# ── Voice: STT (Whisper) ─────────────────────────────────────────────────
# Pi voice path — whisper.cpp on Jetson (POST /api/voice/transcribe)
# ZOE_WHISPER_CPP_BIN=/home/zoe/whisper.cpp/build/bin/whisper-cli
# ZOE_WHISPER_MODEL=/path/to/ggml-base.en.bin
# ZOE_WHISPER_LANG=en
# ZOE_WHISPER_EXTRA_ARGS=-nt
# ZOE_WHISPER_TIMEOUT_S=30
#
# ── Voice: TTS waterfall ─────────────────────────────────────────────────
# TTS mode: hybrid (local → kokoro → edge → espeak), local, cloud, edge, offline
# ZOE_TTS_MODE=hybrid
# Edge TTS voice (cloud fallback — Australian neural)
# ZOE_EDGE_TTS_VOICE=en-AU-NatashaNeural
# Edge TTS network timeout in seconds (failover to Kokoro ONNX on timeout)
# ZOE_EDGE_TTS_TIMEOUT_S=5
# Kokoro ONNX model path (download from https://github.com/thewh1teagle/kokoro-onnx/releases)
# ZOE_KOKORO_MODEL=/opt/models/kokoro-v1.0.onnx
# Kokoro voice: af_sky (AU female), bf_emma (UK female), af_bella (US female)
# ZOE_KOKORO_VOICE=af_sky
# URL for a running Kokoro/Piper sidecar service (optional, fastest path)
# ZOE_LOCAL_TTS_URL=http://localhost:8880
#
# ── Voice: wake acknowledgement phrase (spoken on wake word) ─────────────
# Leave empty to use only the wake beep.
# ZOE_WAKE_ACK_PHRASE=
#
# ── Voice: barge-in ──────────────────────────────────────────────────────
# BARGE_IN_ENABLED=true
# BARGE_IN_THRESHOLD=0.5
# POST_TTS_PROTECTION_MS=300
#
# ── Voice: ambient memory (always-on listening) ───────────────────────────
# OFF by default — opt in explicitly for privacy transparency.
# AMBIENT_CAPTURE_ENABLED=false
# AMBIENT_VAD_THRESHOLD=0.4
