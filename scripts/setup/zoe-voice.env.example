# Zoe Voice Daemon Environment Configuration
# Copy to /etc/zoe-voice.env and fill in your values:
#   sudo cp zoe-voice.env.example /etc/zoe-voice.env
#   sudo nano /etc/zoe-voice.env
#   sudo systemctl enable --now zoe-voice

# Required: Device token from Zoe panel auth
# Generate via: POST /api/panels/devices/register
DEVICE_TOKEN=your-device-token-here

# Zoe API base URL
ZOE_URL=https://zoe.local

# Panel identifier (shows up in panel list)
PANEL_ID=zoe-touch-main

# Microphone device index (run: python3 -c "import pyaudio; p=pyaudio.PyAudio(); [print(i, p.get_device_info_by_index(i)['name']) for i in range(p.get_device_count())]")
MIC_DEVICE_INDEX=0

# SSL verification (set to 0 for self-signed certs on local network)
VERIFY_SSL=0

# Wake word sensitivity (0.0-1.0, lower = more sensitive but more false positives)
OWW_THRESHOLD=0.5
