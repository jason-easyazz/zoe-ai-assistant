!labs/functiongemma-feasibility/zoe_tools.json
!labs/functiongemma-feasibility/results/*.json

# SetFit router head (shadow mode): the 38 KB logreg artifact is tracked
# deliberately; the runtime shadow log is not.
!services/zoe-data/models/
services/zoe-data/models/*
!services/zoe-data/models/router_head_logreg.joblib
!services/zoe-data/models/router_head_mlp.joblib
services/zoe-data/data/router_head_shadow.jsonl

# Router self-training loop — miner (labs/router-selftrain/) + orchestrator
# (scripts/maintenance/router_selftrain.py). Candidate datasets are mined from
# REAL family utterances (raw text) and must NEVER be committed; the run
# journals, scoreboard, work dirs and multi-hundred-MB GGUFs are local runtime
# artifacts. See labs/router-selftrain/README.md and
# docs/knowledge/router-selftrain-loop.md.
data/router_selftrain/

# Live-tree runtime artifacts that were polluting `git status` on the live
# checkout and (before deploy_live.sh's require_clean_tree was hardened) blocked
# the blessed deploy. None are load-bearing; all are regenerated at run time.
# ChromaDB vector store (memory embeddings)
data/chroma/
# Music Assistant runtime state (auth.db/library.db are already tracked; these
# are the runtime sidecars/backups/generated playlists that must never be)
data/music-assistant/*.db-shm
data/music-assistant/*.bak.*
data/music-assistant/playlists/
# Music discovery batch working dir (weekly "Zoe Discovery" run output)
services/zoe-data/data/music_discovery/
# HACS — Home Assistant Community Store, installed into the live HA runtime
homeassistant/custom_components/hacs/
# auth_oidc — HACS-installed OIDC auth provider (christiaangoossens/hass-oidc-auth).
# Third-party runtime code like hacs/ above: configured by configuration.yaml, not vendored.
homeassistant/custom_components/auth_oidc/
# localtuya — local control of Tuya/Grid Connect devices (xZetsubou/hass-localtuya).
# Same class as the two above: third-party runtime code, configured via its UI
# config flow (device ids + local keys are per-install secrets), not vendored.
homeassistant/custom_components/localtuya/
# router-90-campaign: the *.json negation above force-tracks committed
# measurement artifacts; gen1-lineage.json is a runtime lineage journal, not one.
labs/router-90-campaign/results/gen1-lineage.json
