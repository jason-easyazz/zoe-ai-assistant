services/zoe-auth/*.db-shm
services/zoe-auth/*.db-wal
modules/orbit/data/*.db
modules/orbit/data/*.db-shm
modules/orbit/data/*.db-wal


# Wyoming voice models (large; install via scripts/setup)
data/wyoming/

# SECURITY: Never commit secrets or API keys
