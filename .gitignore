# Vendor/Library files (large, versioned separately)
services/zoe-ui/dist/lib/livekit/*
# ...except the LiveKit client the touch UI actually loads at runtime. Nothing
# fetched or versioned it — it survived only as an untracked file on one box, so
# a fresh clone served a 404. It is pinned vendor source (livekit-client 2.5.0,
# Apache-2.0, jsDelivr /npm/livekit-client@2.5.0/dist/livekit-client.umd.js),
# like dist/lib/gridstack/ which is tracked for the same reason.
!services/zoe-ui/dist/lib/livekit/livekit-client.umd.min.js

# Game / pub modules — keep local only; omit from GitHub pushes
modules/jag-board/
modules/questionable-decisions/
modules/questionable-decisions-v1-backup/
tests/unit/test_jag_board_game_store.py

# Runtime SQLite caches
data/touch_cache/

# graphify — RETIRED. Any local graphify-out/ is generated and never committed.
# Code intelligence is provided by the codebase-memory MCP (re-indexed on demand).
graphify-out/
!.cursor/mcp.json
.cursor/tmp/

# Runtime artifacts — generated at run time, never load-bearing (untracked in chore/untrack-runtime-artifacts)
homeassistant/.ha_run.lock
data/music-assistant/*.log
data/music-assistant/*.log.*
data/skills.lock
# autoresearch run dirs are runtime output; the FEATURE is live but reads live run-dirs, not committed samples
data/autoresearch/*/
labs/flue-zoe-brain/parity/gate-results/

