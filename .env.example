# Root environment file for Zoe.
# Copy to .env and replace every "replace-with-*" placeholder.
# This file is loaded by the host-native services (zoe-data, hermes-agent,
# openclaw-gateway) via systemd EnvironmentFile. NEVER commit your real .env.
# Service-specific extras (voice/STT/TTS, OIDC, etc.) live in
# services/zoe-data/.env.example.

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────
# Must match the password used when init_databases.sh created the role.
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_URL=postgresql://zoe:replace-with-db-password@localhost:5432/zoe
POSTGRES_APSCHEDULER_URL=postgresql+psycopg2://zoe:replace-with-db-password@localhost:5432/zoe

# ── Agent gateways ───────────────────────────────────────────────────────
# Shared token between zoe-data and the OpenClaw gateway.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
OPENCLAW_GATEWAY_TOKEN=replace-with-strong-token
# API keys for the engineering/agent tiers (set the ones you use).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HERMES_API_KEY=
LITELLM_API_KEY=

# ── Home Assistant ───────────────────────────────────────────────────────
# Long-lived access token (HA profile → Security → create token named "zoe-data").
HA_ACCESS_TOKEN=replace-with-ha-long-lived-token

# ── Calendar sync (Keeper) ───────────────────────────────────────────────
KEEPER_BASE_URL=http://zoe-keeper:8787
KEEPER_AUTH_TOKEN=replace-with-strong-token
ZOE_CALENDAR_SYNC_ENABLED=false
ZOE_CALENDAR_SYNC_PROVIDER=keeper
